#:import Factory kivy.factory.Factory

<ModernLabel@Label>:
    font_name: 'RacingFont'
    bold: True
    color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)

<InfoBox@BoxLayout>:
    orientation: 'vertical'
    label_text: ''
    value_text: '0'
    unit: ''
    padding: 5
    canvas.before:
        Color:
            rgba: (0, 0, 0, 1) if app.dark_mode else (1, 1, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: (1, 0, 0, 0.4) if app.dark_mode else (0.7, 0, 0, 0.4)
        Line:
            width: 1
            rectangle: (self.x, self.y, self.width, self.height)
    ModernLabel:
        text: root.label_text
        color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
        font_size: '10sp'
    ModernLabel:
        text: root.value_text
        font_size: '20sp'
        color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)
    ModernLabel:
        text: root.unit
        font_size: '8sp'
        color: (0.5, 0.5, 0.5, 1) if app.dark_mode else (0.4, 0.4, 0.4, 1)

<ModernButton@Button>:
    background_normal: ''
    background_color: (0, 0, 0, 0)
    font_name: 'RacingFont'
    bold: True
    canvas.before:
        Color:
            rgba: ((0.8, 0, 0, 1) if self.state == 'down' else (0.1, 0.1, 0.1, 1)) if app.dark_mode else ((0.8, 0, 0, 1) if self.state == 'down' else (0.85, 0.85, 0.85, 1))
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: (1, 0, 0, 0.6) if app.dark_mode else (0.5, 0, 0, 0.6)
        Line:
            width: 1.2
            rectangle: (self.x, self.y, self.width, self.height)
    color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)

<GraphContainer@BoxLayout>:
    orientation: 'vertical'
    title: ''
    value: '0'
    unit: ''
    padding: 10
    canvas.before:
        Color:
            rgba: (0.05, 0.05, 0.05, 1) if app.dark_mode else (0.95, 0.95, 0.95, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        size_hint_y: 0.2
        ModernLabel:
            text: root.title
            color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
            halign: 'left'
            text_size: self.size
        ModernLabel:
            text: root.value + " " + root.unit
            halign: 'right'
            text_size: self.size
            color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)

ScreenManager:
    DashboardScreen:
    AccelerationScreen:
    PerformanceScreen:
    DiagnosticsScreen:

<DashboardScreen>:
    name: 'dashboard'
    FloatLayout:
        canvas.before:
            Color:
                rgba: (0, 0, 0, 1) if app.dark_mode else (0.9, 0.9, 0.9, 1)
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: (1, 0, 0, 0.5 if root.shift_light else 0)
            Line:
                width: 5
                rectangle: (self.width*0.85, self.height*0.85, self.width*0.13, self.height*0.13)

        ModernButton:
            text: "NOCHE" if app.dark_mode else "DIA"
            size_hint: (None, None)
            size: (70, 35)
            pos_hint: {'right': 0.98, 'top': 0.98}
            on_release: app.toggle_mode()
            font_size: '11sp'

        # Status Indicator (Top Center)
        BoxLayout:
            orientation: 'horizontal'
            size_hint: (None, None)
            size: (200, 30)
            pos_hint: {'center_x': 0.5, 'top': 0.98}
            spacing: 10
            Widget:
                size_hint: (None, None)
                size: (15, 15)
                pos_hint: {'center_y': 0.5}
                canvas:
                    Color:
                        rgba: root.status_color
                    Ellipse:
                        pos: self.pos
                        size: self.size
            ModernLabel:
                text: root.status_text
                font_size: '12sp'
                color: root.status_color

        # Marcha (Right)
        BoxLayout:
            orientation: 'vertical'
            size_hint: (None, None)
            size: (100, 80)
            pos_hint: {'right': 0.98, 'top': 0.92}
            ModernLabel:
                text: "MARCHA"
                font_size: '12sp'
                color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
            ModernLabel:
                text: root.gear[0]
                font_size: '60sp'
                color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)

        # Dial Central
        RelativeLayout:
            size_hint: (0.8, 0.5)
            pos_hint: {'center_x': 0.5, 'top': 0.9}
            canvas:
                Color:
                    rgba: (0.15, 0.15, 0.15, 1) if app.dark_mode else (0.8, 0.8, 0.8, 1)
                Line:
                    circle: (self.width/2, self.height/4, min(self.width, self.height)*0.6, -90, 90)
                    width: 15
                Color:
                    rgba: ((1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)) if root.rpm > 4200 else ((1, 1, 1, 1) if app.dark_mode else (0.2, 0.2, 0.2, 1))
                Line:
                    circle: (self.width/2, self.height/4, min(self.width, self.height)*0.6, -90, -90 + (min(root.rpm, 5000) / 5000) * 180)
                    width: 15
                    cap: 'round'
            ModernLabel:
                text: str(int(root.rpm))
                font_size: '90sp'
                pos_hint: {'center_x': 0.5, 'center_y': 0.3}
                color: ((1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)) if root.rpm > 4200 else ((1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1))

        # Sensores
        GridLayout:
            cols: 5
            rows: 2
            spacing: 4
            size_hint: (0.98, 0.25)
            pos_hint: {'center_x': 0.5, 'y': 0.12}
            InfoBox:
                label_text: 'VELOCIDAD'
                value_text: str(int(root.speed))
                unit: 'KM/H'
            InfoBox:
                label_text: 'TURBO'
                value_text: "{:.2f}".format(root.boost)
                unit: 'BAR'
            InfoBox:
                label_text: 'POTENCIA'
                value_text: str(int(root.hp))
                unit: 'CV'
            InfoBox:
                label_text: 'PAR MOTOR'
                value_text: str(int(root.torque))
                unit: 'Nm'
            InfoBox:
                label_text: 'COMBUST.'
                value_text: str(int(root.fuel))
                unit: '%'
            InfoBox:
                label_text: 'TEMP ACEITE'
                value_text: str(int(root.oil_temp))
                unit: '°C'
            InfoBox:
                label_text: 'REFRIGERANTE'
                value_text: str(int(root.temp))
                unit: '°C'
            InfoBox:
                label_text: 'VOLTAJE'
                value_text: "{:.1f}".format(root.voltage)
                unit: 'V'
            InfoBox:
                label_text: 'ADMISIÓN'
                value_text: str(int(root.iat))
                unit: '°C'
            InfoBox:
                label_text: 'ACELERADOR'
                value_text: str(int(root.throttle))
                unit: '%'

        # Botones
        BoxLayout:
            size_hint: (1, 0.08)
            pos_hint: {'y': 0}
            ModernButton:
                text: "ACELERACIÓN"
                on_release: root.manager.current = 'acceleration'
            ModernButton:
                text: "RENDIMIENTO"
                on_release: root.manager.current = 'performance'
            ModernButton:
                text: "DIAGNÓSTICO"
                on_release: root.manager.current = 'diagnostics'

<AccelerationScreen>:
    name: 'acceleration'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0, 0, 0, 1) if app.dark_mode else (0.9, 0.9, 0.9, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # ZONA SUPERIOR (Configuración)
        BoxLayout:
            size_hint_y: 0.12
            padding: [10, 5]
            spacing: 20
            canvas.after:
                Color:
                    rgba: (1, 0, 0, 0.3) if app.dark_mode else (0.5, 0, 0, 0.3)
                Line:
                    points: [self.x, self.y, self.right, self.y]
                    width: 1
            ModernButton:
                text: "[ MODO AUTO ]" if root.mode == "AUTO" else "[ MODO MANUAL ]"
                size_hint_x: 0.4
                on_release: root.toggle_mode()
            ModernLabel:
                text: root.status_msg
                size_hint_x: 0.6
                halign: 'right'
                color: (1, 0, 0, 1) if "CAÑA" in root.status_msg else ((1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1))

        # ZONA CENTRAL (Cronómetro)
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.45
            padding: [0, 20]
            ModernLabel:
                text: root.timer_val
                font_size: '120sp'
                color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)
            ModernLabel:
                text: "(SEGUNDOS - 0 a 100 KM/H)"
                font_size: '12sp'
                color: (0.5, 0.5, 0.5, 1) if app.dark_mode else (0.4, 0.4, 0.4, 1)

        # ZONA INFERIOR (Acción e Historial)
        BoxLayout:
            size_hint_y: 0.43
            padding: 10
            spacing: 10
            
            # Sub-Zona izquierda (Botonera y Volver)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.72
                spacing: 15
                
                # ZONA DE ACCIÓN (Botones)
                BoxLayout:
                    spacing: 10
                    size_hint_y: 0.6
                    ModernButton:
                        text: "¡INICIAR PRUEBA!"
                        font_size: '22sp'
                        color: (1, 1, 1, 1)
                        background_color: (0.6, 0, 0, 1) if self.state == 'normal' else (0.4, 0, 0, 1)
                        disabled: root.mode == "AUTO" or root.active
                        opacity: 1 if root.mode == "MANUAL" else 0.3
                        on_release: root.manual_start()
                    ModernButton:
                        text: "RESETEAR CRONO"
                        font_size: '16sp'
                        on_release: root.reset_timer()
                
                # Botón Volver
                ModernButton:
                    text: "VOLVER AL PANEL PRINCIPAL"
                    size_hint_y: 0.4
                    on_release: root.manager.current = 'dashboard'

            # ZONA DERECHA (Historial)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.28
                padding: 5
                canvas.before:
                    Color:
                        rgba: (0.05, 0.05, 0.05, 1) if app.dark_mode else (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: (1, 0, 0, 0.4) if app.dark_mode else (0.7, 0, 0, 0.4)
                    Line:
                        width: 1
                        rectangle: (self.x, self.y, self.width, self.height)
                ModernLabel:
                    text: "ÚLTIMOS TIEMPOS"
                    size_hint_y: 0.2
                    font_size: '11sp'
                    color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
                ScrollView:
                    size_hint_y: 0.8
                    ModernLabel:
                        text: "\n".join([f"{i+1}. {run['time']} - {run['date'].split()[0]}" for i, run in enumerate(root.history)])
                        font_size: '10sp'
                        halign: 'left'
                        valign: 'top'
                        text_size: self.size
                        line_height: 1.2
                        color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)

<PerformanceScreen>:
    name: 'performance'
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10
        canvas.before:
            Color:
                rgba: (0, 0, 0, 1) if app.dark_mode else (0.9, 0.9, 0.9, 1)
            Rectangle:
                pos: self.pos
                size: self.size
        
        ModernLabel:
            text: "GRÁFICAS DE RENDIMIENTO"
            size_hint_y: 0.08
            color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
            font_size: '20sp'

        GraphContainer:
            title: 'TURBO REAL'
            value: "{:.2f}".format(root.boost)
            unit: 'BAR'
            RealTimeGraph:
                id: graph_boost
                max_val: 2.0
                line_color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)

        GraphContainer:
            title: 'POTENCIA REAL'
            value: str(int(root.hp))
            unit: 'CV'
            RealTimeGraph:
                id: graph_hp
                max_val: 150
                line_color: (1, 1, 1, 1) if app.dark_mode else (0.2, 0.2, 0.2, 1)

        GraphContainer:
            title: 'PAR MOTOR REAL'
            value: str(int(root.torque))
            unit: 'Nm'
            RealTimeGraph:
                id: graph_torque
                max_val: 350
                line_color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)

        ModernButton:
            text: "VOLVER AL PANEL PRINCIPAL"
            size_hint_y: 0.15
            on_release: root.manager.current = 'dashboard'

<DiagnosticsScreen>:
    name: 'diagnostics'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10
        canvas.before:
            Color:
                rgba: (0, 0, 0, 1) if app.dark_mode else (0.9, 0.9, 0.9, 1)
            Rectangle:
                pos: self.pos
                size: self.size
        ModernLabel:
            text: "DIAGNÓSTICO ECU"
            size_hint_y: 0.1
            color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
        ScrollView:
            size_hint_y: 0.7
            GridLayout:
                id: dtc_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 5
        BoxLayout:
            size_hint_y: 0.25
            spacing: 10
            ModernButton:
                text: "ESCANEAR"
                on_release: root.refresh_dtc()
            ModernButton:
                text: "BORRAR"
                on_release: root.clear_dtc()
            ModernButton:
                text: "VOLVER AL PANEL PRINCIPAL"
                on_release: root.manager.current = 'dashboard'

<DTCItem@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    height: '60dp'
    padding: 5
    code: ''
    desc: ''
    canvas.before:
        Color:
            rgba: (0.1, 0.1, 0.1, 1) if app.dark_mode else (0.85, 0.85, 0.85, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    ModernLabel:
        text: root.code
        color: (1, 0, 0, 1) if app.dark_mode else (0.7, 0, 0, 1)
    ModernLabel:
        text: root.desc
        font_size: '12sp'
        color: (1, 1, 1, 1) if app.dark_mode else (0.1, 0.1, 0.1, 1)
